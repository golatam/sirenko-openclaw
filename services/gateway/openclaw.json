{
  "agents": {
    "defaults": {
      "workspace": "/data/openclaw-state/workspace",
      "memorySearch": {
        "enabled": true,
        "provider": "mistral",
        "model": "mistral-embed"
      }
    }
  },
  "cron": {
    "enabled": true
  },
  "tools": {
    "alsoAllow": ["lobster"],
    "media": {
      "audio": {
        "enabled": true,
        "models": [{ "provider": "groq", "model": "whisper-large-v3" }]
      }
    }
  },
  "gateway": {
    "bind": "lan",
    "trustedProxies": ["100.64.0.1", "100.64.0.2", "100.64.0.3", "100.64.0.4", "100.64.0.5", "100.64.0.6", "100.64.0.7", "100.64.0.8", "100.64.0.9", "100.64.0.10", "100.64.0.11", "100.64.0.12"],
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowedOrigins": ["https://gateway-production-1382.up.railway.app"]
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": ["tg:7664703896"],
      "actions": { "sendMessage": true },
      "groups": {
        "*": { "requireMention": true }
      }
    },
    "slack": {
      "enabled": true,
      "mode": "socket",
      "appToken": "${SLACK_APP_TOKEN}",
      "botToken": "${SLACK_BOT_TOKEN}",
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "groupPolicy": "open",
      "channels": {
        "*": { "requireMention": false }
      },
      "nativeStreaming": true,
      "replyToMode": "all"
    }
  },
  "plugins": {
    "enabled": true,
    "allow": ["work-agent", "telegram", "memory-core", "lobster"],
    "slots": {
      "memory": "memory-core"
    },
    "load": {
      "paths": ["/app/work-agent"]
    },
    "entries": {
      "telegram": {
        "enabled": true
      },
      "work-agent": {
        "enabled": true,
        "config": {
          "mcpServerUrl": "${GOOGLE_MCP_URL}",
          "telegramSidecarUrl": "${TELEGRAM_SIDECAR_URL}",
          "tavilyApiKey": "${TAVILY_API_KEY}",
          "amplitudeOAuthClientId": "${AMPLITUDE_OAUTH_CLIENT_ID}",
          "amplitudeOAuthAccessToken": "${AMPLITUDE_OAUTH_ACCESS_TOKEN}",
          "amplitudeOAuthRefreshToken": "${AMPLITUDE_OAUTH_REFRESH_TOKEN}",
          "sidecarAuthToken": "${SIDECAR_AUTH_TOKEN}",
          "databaseUrl": "${DATABASE_URL}",
          "whatsappSidecarUrl": "${WHATSAPP_SIDECAR_URL}",
          "tallyApiKey": "${TALLY_API_KEY}"
        }
      },
      "memory-core": {
        "enabled": true
      },
      "lobster": {
        "enabled": true
      }
    }
  }
}
