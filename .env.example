# .env.example — Copy to .env and fill in values
# .env is gitignored — secrets never committed

# --- Gateway (OpenClaw) ---
ANTHROPIC_OAUTH_TOKEN=
OPENCLAW_GATEWAY_TOKEN=
TELEGRAM_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
GROQ_API_KEY=
TAVILY_API_KEY=
GEMINI_API_KEY=

# --- Google MCP Sidecar ---
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=
# JSON array: [{"account":"kirill@sirenko.ru","refreshToken":"..."},...]
GOOGLE_WORKSPACE_ACCOUNTS=

# --- Amplitude MCP Sidecar ---
AMPLITUDE_API_KEY=
AMPLITUDE_SECRET_KEY=

# --- Sidecar Auth (shared across all sidecars) ---
SIDECAR_AUTH_TOKEN=

# --- Telegram Sidecar ---
# Account 1
TG1_API_ID=
TG1_API_HASH=
TG1_PHONE=
TG1_SESSION=
# Account 2
TG2_API_ID=
TG2_API_HASH=
TG2_PHONE=
TG2_SESSION=
# Account 3
TG3_API_ID=
TG3_API_HASH=
TG3_PHONE=
TG3_SESSION=
